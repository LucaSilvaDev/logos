# ─── Banco de dados (Turso / libSQL) ───────────────────────────────
TURSO_DATABASE_URL="libsql://your-db.turso.io"
TURSO_AUTH_TOKEN=""

# ─── NextAuth ──────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=""
# URL pública da aplicação (sem barra no final). Em produção, sua URL Vercel.
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ──────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Resend (e-mail de redefinição de senha) ───────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=""

# ─── APIs externas da Bíblia ───────────────────────────────────────
# Opcional: token de https://www.abibliadigital.com.br
BIBLE_API_TOKEN=""
# Opcional: chave de aplicativo de https://platform.youversion.com
YOUVERSION_APP_KEY=""

# ─── Notificações Push (Web Push / VAPID) ──────────────────────────
# Gere com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:contato@seudominio.com"

# ─── Cron job (Vercel) ─────────────────────────────────────────────
# Token compartilhado entre vercel.json e /api/push/send.
# Gere com: openssl rand -hex 32
CRON_SECRET=""
