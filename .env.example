# ─── Banco de dados local (desenvolvimento) ────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── Turso / libSQL (produção) ─────────────────────────────────────────────────
# Crie um banco gratuito em: https://turso.tech
# Após criar, copie a URL e o token de auth do dashboard
TURSO_DATABASE_URL="libsql://seu-banco.turso.io"
TURSO_AUTH_TOKEN=""

# ─── NextAuth v5 ───────────────────────────────────────────────────────────────
# Gere um secret seguro com: openssl rand -base64 32
NEXTAUTH_SECRET=""
# URL pública da aplicação (sem barra final). Em produção, sua URL Vercel
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth (login com Google) ───────────────────────────────────────────
# 1. Acesse: https://console.cloud.google.com/apis/credentials
# 2. Crie um "OAuth 2.0 Client ID" do tipo "Web application"
# 3. Adicione http://localhost:3000/api/auth/callback/google como Redirect URI
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Resend (e-mail de redefinição de senha) ───────────────────────────────────
# Crie uma conta e gere uma API key em: https://resend.com/api-keys
RESEND_API_KEY=""

# ─── API Bíblia Digital ────────────────────────────────────────────────────────
# Crie conta gratuita em: https://www.abibliadigital.com.br
# Após criar conta: Minha Conta > Token
BIBLE_API_TOKEN=""
BIBLE_API_URL="https://www.abibliadigital.com.br/api"

# ─── YouVersion Platform (versões NVT e A21) ───────────────────────────────────
# 1. Crie conta em: https://platform.youversion.com
# 2. Aceite a licença das versões desejadas
# 3. Copie o App Key
YOUVERSION_APP_KEY=""

# ─── Web Push / VAPID (notificações push) ──────────────────────────────────────
# Gere as chaves com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:seu@email.com"

# ─── Cron secret (protege o endpoint /api/push/send) ──────────────────────────
# Token compartilhado entre vercel.json e /api/push/send. Gere com: openssl rand -hex 32
CRON_SECRET=""
